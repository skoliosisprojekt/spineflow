{
  "expo": {
    "name": "SpineFlow",
    "slug": "SpineFlow",
    "version": "1.0.6",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "spineflow",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/images/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#1E5B87"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png",
        "backgroundColor": "#1E5B87"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.skoliosisprojekt.SpineFlow",
      "versionCode": 5,
      "permissions": [
        "android.permission.VIBRATE",
        "android.permission.WAKE_LOCK"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/images/favicon.png",
      "meta": {
        "viewport": {
          "width": "device-width",
          "initial-scale": 1,
          "maximum-scale": 1,
          "user-scalable": false
        }
      },
      "resources": [
        "./web.css"
      ]
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-localization",
      "expo-sqlite",
      "expo-image",
      "expo-sharing"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "9fb0cb68-2c03-42ef-a902-50fc71d3b4e0"
      }
    },
    "owner": "skoliosisprojekt"
  }
}
